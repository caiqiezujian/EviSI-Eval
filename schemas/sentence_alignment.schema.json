{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/evisi/sentence-alignment-0.4.1.schema.json",
  "title": "EviSI-Eval Sentence Alignment 0.4.1",
  "type": "object",
  "required": ["target_units", "sentence_alignments", "unaligned_target_unit_ids"],
  "properties": {
    "target_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["unit_id", "unit_text"],
        "properties": {
          "unit_id": {"type": "string", "minLength": 1},
          "unit_text": {"type": "string", "minLength": 1}
        }
      }
    },
    "sentence_alignments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_sentence_id", "source_sentence_text", "target_unit_ids", "target_spans", "alignment_type", "group_id", "confidence", "reason"],
        "properties": {
          "source_sentence_id": {"type": "string"},
          "source_sentence_text": {"type": "string"},
          "target_unit_ids": {"type": "array", "items": {"type": "string"}},
          "target_spans": {"type": "array", "items": {"type": "string"}},
          "alignment_type": {"enum": ["one_to_one", "one_to_many", "many_to_one", "omitted", "uncertain"]},
          "group_id": {"type": ["string", "null"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "reason": {"type": "string"}
        }
      }
    },
    "unaligned_target_unit_ids": {"type": "array", "items": {"type": "string"}}
  }
}

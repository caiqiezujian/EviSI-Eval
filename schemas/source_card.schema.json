{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/evisi/source-card-v0.5.schema.json",
  "title": "EviSI-Eval v0.5 Frozen Source Card",
  "type": "object",
  "required": ["sample_id", "source_text", "source_units", "source_anchors", "source_events", "source_relations", "metadata"],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "source_text": {"type": "string", "minLength": 1},
    "reference_translation": {"type": ["string", "null"]},
    "src_lang": {"type": "string"},
    "tgt_lang": {"type": "string"},
    "domain": {"type": "string"},
    "source_units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source_unit"}},
    "source_anchors": {"type": "array", "items": {"$ref": "#/$defs/source_anchor"}},
    "source_events": {"type": "array", "items": {"$ref": "#/$defs/source_event"}},
    "source_relations": {"type": "array", "items": {"$ref": "#/$defs/source_relation"}},
    "metadata": {
      "type": "object",
      "required": ["protocol_version", "source_card_hash", "frozen_before_system_evaluation", "system_outputs_visible", "agent_trace", "prompt_hashes"]
    }
  },
  "$defs": {
    "importance": {"type": "integer", "enum": [1, 2, 3]},
    "source_unit": {
      "type": "object", "required": ["source_unit_id", "source_unit"],
      "properties": {"source_unit_id": {"type": "string", "pattern": "^S[1-9][0-9]*$"}, "source_unit": {"type": "string", "minLength": 1}}
    },
    "source_anchor": {
      "type": "object", "required": ["source_unit_id", "source_anchor_id", "anchor_type", "anchor_text", "normalized_meaning", "evidence_span", "importance"],
      "properties": {"source_anchor_id": {"type": "string", "pattern": "^SA[1-9][0-9]*$"}, "anchor_type": {"enum": ["A-ENT", "A-QNT", "A-TMP", "A-TERM", "A-SCOPE"]}, "importance": {"$ref": "#/$defs/importance"}}
    },
    "source_event": {
      "type": "object", "required": ["source_unit_id", "source_event_id", "event_type", "event_text", "canonical_meaning", "evidence_span", "importance"],
      "properties": {"source_event_id": {"type": "string", "pattern": "^SE[1-9][0-9]*$"}, "event_type": {"enum": ["E-ACT", "E-STATE", "E-CHANGE", "E-JUDG", "E-REL", "E-SPEECH", "E-MODAL"]}, "importance": {"$ref": "#/$defs/importance"}}
    },
    "source_relation": {
      "type": "object", "required": ["source_relation_id", "relation_type", "source_unit_ids", "relation_text", "relation_meaning", "evidence_spans", "related_source_event_ids", "importance"],
      "properties": {"source_relation_id": {"type": "string", "pattern": "^SR[1-9][0-9]*$"}, "relation_type": {"type": "string"}, "importance": {"$ref": "#/$defs/importance"}}
    }
  }
}

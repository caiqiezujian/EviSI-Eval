{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/evisi/source-card-0.4.1.schema.json",
  "title": "EviSI-Eval Source Card 0.4.1",
  "type": "object",
  "required": ["sample_id", "source_text", "sentences", "anchors", "events", "relations", "allowed_omissions", "metadata"],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "source_text": {"type": "string", "minLength": 1},
    "offline_translation": {"type": ["string", "null"]},
    "src_lang": {"type": "string"},
    "tgt_lang": {"type": "string"},
    "domain": {"type": "string"},
    "sentences": {"type": "array", "items": {"$ref": "#/$defs/sentence"}},
    "anchors": {"type": "array", "items": {"$ref": "#/$defs/anchor"}},
    "events": {"type": "array", "items": {"$ref": "#/$defs/event"}},
    "relations": {"type": "array", "items": {"$ref": "#/$defs/relation"}},
    "allowed_omissions": {"type": "array", "items": {"type": "object", "required": ["source_span", "reason"]}},
    "metadata": {"type": "object", "required": ["schema_version", "card_hash", "card_status"]}
  },
  "$defs": {
    "sentence": {"type": "object", "required": ["sentence_id", "sentence_text", "anchor_ids"], "properties": {"sentence_id": {"type": "string"}, "sentence_text": {"type": "string"}, "anchor_ids": {"type": "array", "items": {"type": "string"}}}},
    "anchor": {"type": "object", "required": ["anchor_id", "sentence_id", "source_span", "normalized_value", "anchor_type", "importance", "required", "confidence"], "properties": {"anchor_id": {"type": "string"}, "sentence_id": {"type": "string"}, "source_span": {"type": "string"}, "normalized_value": {"type": "string"}, "anchor_type": {"type": "string"}, "importance": {"enum": [1, 2, 3]}, "required": {"type": "boolean"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}}},
    "event": {"type": "object", "required": ["event_id", "sentence_id", "evidence_spans", "canonical_meaning", "predicate", "arguments", "linked_anchor_ids", "attributes", "importance", "required", "confidence"], "properties": {"event_id": {"type": "string"}, "sentence_id": {"type": "string"}, "evidence_spans": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "canonical_meaning": {"type": "string"}, "predicate": {"type": "string"}, "arguments": {"type": "array"}, "linked_anchor_ids": {"type": "array", "items": {"type": "string"}}, "attributes": {"type": "object"}, "importance": {"enum": [1, 2, 3]}, "required": {"type": "boolean"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}}},
    "relation": {"type": "object", "required": ["relation_id", "relation_type", "head_event_id", "dependent_event_id", "source_cues", "canonical_meaning", "importance", "required", "confidence"]}
  }
}

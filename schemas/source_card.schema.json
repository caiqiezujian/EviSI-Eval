{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/evisi/source-card-v0.3.schema.json",
  "title": "EviSI-Eval v0.3 Source Card",
  "type": "object",
  "required": ["sample_id", "source_text", "source_units", "source_anchors", "source_events", "source_relations", "metadata"],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "source_text": {"type": "string", "minLength": 1},
    "reference_translation": {"type": ["string", "null"]},
    "src_lang": {"type": "string"},
    "tgt_lang": {"type": "string"},
    "domain": {"type": "string"},
    "source_units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source_unit"}},
    "source_anchors": {"type": "array", "items": {"$ref": "#/$defs/source_anchor"}},
    "source_events": {"type": "array", "items": {"$ref": "#/$defs/source_event"}},
    "source_relations": {"type": "array", "items": {"$ref": "#/$defs/source_relation"}},
    "metadata": {"type": "object", "required": ["protocol_version", "source_card_hash", "agent_trace", "prompt_hashes"]}
  },
  "$defs": {
    "source_unit": {
      "type": "object",
      "required": ["source_unit_id", "source_unit"],
      "properties": {"source_unit_id": {"type": "string"}, "source_unit": {"type": "string"}}
    },
    "source_anchor": {
      "type": "object",
      "required": ["source_unit_id", "source_anchor_id", "anchor_text", "normalized_meaning", "evidence_span"]
    },
    "source_event": {
      "type": "object",
      "required": ["source_unit_id", "source_event_id", "event_text", "canonical_meaning", "evidence_span"]
    },
    "source_relation": {
      "type": "object",
      "required": ["source_relation_id", "source_unit_ids", "relation_text", "relation_meaning", "evidence_spans", "related_source_event_ids"]
    }
  }
}

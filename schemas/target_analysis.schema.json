{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/evisi/target-analysis-0.4.1.schema.json",
  "title": "EviSI-Eval Target Semantic Analysis 0.4.1",
  "type": "object",
  "required": ["target_units", "target_anchors", "target_events", "target_relations"],
  "properties": {
    "target_units": {"type": "array", "items": {"type": "object", "required": ["unit_id", "unit_text"]}},
    "target_anchors": {"type": "array", "items": {"type": "object", "required": ["target_anchor_id", "unit_id", "target_span", "normalized_value", "anchor_type", "attributes", "confidence"]}},
    "target_events": {"type": "array", "items": {"type": "object", "required": ["target_event_id", "unit_ids", "evidence_spans", "canonical_meaning", "predicate", "arguments", "attributes", "confidence"]}},
    "target_relations": {"type": "array", "items": {"type": "object", "required": ["target_relation_id", "relation_type", "head_target_event_id", "dependent_target_event_id", "target_cues", "canonical_meaning", "confidence"]}}
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EviSI Evaluation Card v1.1",
  "type": "object",
  "required": ["sample_id", "transcript", "facts", "propositions", "relations", "terminology", "allowed_omissions", "forbidden_losses", "metadata"],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "transcript": {"type": "string", "minLength": 1},
    "offline_translation": {"type": ["string", "null"]},
    "src_lang": {"type": "string"},
    "tgt_lang": {"type": "string"},
    "domain": {"type": "string"},
    "facts": {"type": "array", "items": {"$ref": "#/$defs/fact"}},
    "entity_occurrences": {
      "type": "array",
      "description": "Flat list of sentence-level entity occurrences (Stage 1 of card builder v1.1). Mirrors the data embedded inside `sentences[].entity_occurrences`.",
      "items": {"$ref": "#/$defs/entity_occurrence"}
    },
    "sentences": {
      "type": "array",
      "description": "Sentence-segmented view of the transcript. Each sentence carries its own entity_occurrences. Added in card builder v1.1.",
      "items": {"$ref": "#/$defs/sentence"}
    },
    "global_entity_inventory": {
      "type": "array",
      "description": "Auxiliary index that aggregates occurrences of the same canonical entity across the whole document. NEVER use this as the primary scoring source — sentence-level entity_occurrences are authoritative.",
      "items": {"$ref": "#/$defs/global_entity"}
    },
    "propositions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/proposition"}},
    "relations": {"type": "array", "items": {"$ref": "#/$defs/relation"}},
    "terminology": {"type": "array"},
    "allowed_omissions": {"type": "array"},
    "forbidden_losses": {"type": "array"},
    "metadata": {
      "type": "object",
      "required": ["schema_version", "prompt_version", "card_status", "card_hash", "system_outputs_visible_to_builder"]
    }
  },
  "$defs": {
    "fact": {
      "type": "object",
      "required": ["fact_id", "source_span", "importance", "must_preserve", "extraction_confidence"],
      "properties": {
        "fact_id": {"type": "string"},
        "type": {"type": "string"},
        "entity_type": {
          "enum": ["PERSON", "ORG", "GPE", "LOCATION", "TIME", "DATE", "NUMBER", "MONEY", "PERCENT", "UNIT", "PRODUCT", "EVENT", "LAW_POLICY", "PROJECT", "TECH_TERM", "DOMAIN_TERM", "KEY_CONCEPT", "POLARITY", "DIRECTION", "SCOPE", "MODALITY", "OTHER"]
        },
        "sentence_id": {"type": "string"},
        "sentence_text": {"type": "string"},
        "source_span": {"type": "string"},
        "canonical_value": {},
        "normalized_entity": {"type": "string"},
        "importance": {
          "oneOf": [
            {"type": "integer", "minimum": 1, "maximum": 3},
            {"enum": ["high", "medium", "low"]}
          ]
        },
        "importance_numeric": {"type": "integer", "minimum": 1, "maximum": 3},
        "must_preserve": {"type": "boolean"},
        "is_score_anchor": {"type": "boolean"},
        "role_hint": {
          "enum": ["subject", "object", "time", "place", "quantity", "topic", "term", "modifier", "reference", "other"]
        },
        "acceptable_variants": {"type": "array", "items": {"type": "string"}},
        "extraction_confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "entity_occurrence": {
      "type": "object",
      "required": ["occurrence_id", "sentence_id", "sentence_text", "entity_text", "normalized_entity", "entity_type", "importance", "is_score_anchor", "role_hint", "extraction_reason"],
      "properties": {
        "occurrence_id": {"type": "string"},
        "sentence_id": {"type": "string"},
        "sentence_text": {"type": "string"},
        "entity_text": {"type": "string"},
        "normalized_entity": {"type": "string"},
        "entity_type": {
          "enum": ["PERSON", "ORG", "GPE", "LOCATION", "TIME", "DATE", "NUMBER", "MONEY", "PERCENT", "UNIT", "PRODUCT", "EVENT", "LAW_POLICY", "PROJECT", "TECH_TERM", "DOMAIN_TERM", "KEY_CONCEPT", "POLARITY", "DIRECTION", "SCOPE", "MODALITY", "OTHER"]
        },
        "importance": {"enum": ["high", "medium", "low"]},
        "is_score_anchor": {"type": "boolean"},
        "role_hint": {
          "enum": ["subject", "object", "time", "place", "quantity", "topic", "term", "modifier", "reference", "other"]
        },
        "extraction_reason": {"type": "string"}
      }
    },
    "sentence": {
      "type": "object",
      "required": ["sentence_id", "sentence_text", "entity_occurrences"],
      "properties": {
        "sentence_id": {"type": "string"},
        "sentence_text": {"type": "string"},
        "entity_occurrences": {"type": "array", "items": {"$ref": "#/$defs/entity_occurrence"}}
      }
    },
    "global_entity": {
      "type": "object",
      "required": ["normalized_entity", "entity_type", "occurs_in_sentences", "occurrence_ids"],
      "properties": {
        "normalized_entity": {"type": "string"},
        "entity_type": {"type": "string"},
        "occurs_in_sentences": {"type": "array", "items": {"type": "string"}},
        "occurrence_ids": {"type": "array", "items": {"type": "string"}},
        "note": {"type": "string"}
      }
    },
    "proposition": {
      "type": "object",
      "required": ["prop_id", "source_span", "canonical_meaning", "importance", "required", "extraction_confidence"],
      "properties": {
        "prop_id": {"type": "string"},
        "source_span": {"type": "string"},
        "canonical_meaning": {"type": "string"},
        "target_reference": {"type": ["string", "null"]},
        "importance": {"type": "integer", "minimum": 1, "maximum": 3},
        "required": {"type": "boolean"},
        "linked_entities": {"type": "array", "items": {"type": "string"}},
        "linked_facts": {"type": "array", "items": {"type": "string"}},
        "notes": {"type": ["string", "null"]},
        "extraction_confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "relation": {
      "type": "object",
      "required": ["relation_id", "type", "source_cues", "head_prop_id", "dependent_prop_id", "canonical_meaning", "importance", "extraction_confidence"],
      "properties": {
        "relation_id": {"type": "string"},
        "type": {"type": "string"},
        "source_cues": {"type": "array", "items": {"type": "string"}},
        "head_prop_id": {"type": "string"},
        "dependent_prop_id": {"type": "string"},
        "canonical_meaning": {"type": "string"},
        "importance": {"type": "integer", "minimum": 1, "maximum": 3},
        "extraction_confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}

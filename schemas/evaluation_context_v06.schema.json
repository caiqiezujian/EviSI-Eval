{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/evisi/evaluation-context-v06.schema.json",
  "title": "EviSI-Eval v0.6 Evaluation Context Card",
  "type": "object",
  "required": [
    "sample_id", "source_card_hash", "reference_card_hash",
    "reference_type", "item_links", "metadata"
  ],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "source_card_hash": {"type": "string", "minLength": 1},
    "reference_card_hash": {"type": "string", "minLength": 1},
    "reference_type": {"type": "string", "minLength": 1},
    "item_links": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchors", "events", "relations"],
      "properties": {
        "anchors": {"type": "array", "items": {"$ref": "#/$defs/link"}},
        "events": {"type": "array", "items": {"$ref": "#/$defs/link"}},
        "relations": {"type": "array", "items": {"$ref": "#/$defs/link"}}
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "protocol_version", "source_is_semantic_authority",
        "reference_is_auxiliary", "constructed_without_llm",
        "evaluation_context_hash"
      ]
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "required": ["reference_projection_id", "reference_mapping_status"],
      "properties": {
        "source_anchor_id": {"type": "string"},
        "source_event_id": {"type": "string"},
        "source_relation_id": {"type": "string"},
        "reference_projection_id": {"type": "string"},
        "reference_mapping_status": {
          "enum": ["equivalent", "partial", "contradiction", "missing", "uncertain", "not_scored"]
        }
      }
    }
  }
}

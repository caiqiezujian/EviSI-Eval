{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/evisi/target-eval-card-v0.3.schema.json",
  "title": "EviSI-Eval v0.3 Target Evaluation Card",
  "type": "object",
  "required": ["sample_id", "system_name", "si_translation", "eval_units", "target_anchors", "target_events", "target_relations", "fluency_issues", "fluency_assessment", "si_expression_issues", "si_expression_assessment", "metadata"],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "system_name": {"type": "string", "minLength": 1},
    "si_translation": {"type": "string", "minLength": 1},
    "eval_units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/eval_unit"}},
    "target_anchors": {"type": "array"},
    "target_events": {"type": "array"},
    "target_relations": {"type": "array"},
    "fluency_issues": {"type": "array"},
    "fluency_assessment": {"type": "string"},
    "si_expression_issues": {"type": "array"},
    "si_expression_assessment": {"type": "string"},
    "metadata": {"type": "object", "required": ["protocol_version", "system_name_visible_to_agents", "reference_translation_used"]}
  },
  "$defs": {
    "eval_unit": {
      "type": "object",
      "required": ["eval_unit_id", "source_unit_ids", "target_unit", "alignment_status", "reason"],
      "properties": {
        "eval_unit_id": {"type": "string"},
        "source_unit_ids": {"type": "array", "items": {"type": "string"}},
        "target_unit": {"type": "string"},
        "alignment_status": {"enum": ["aligned", "source_omitted", "target_addition", "uncertain"]},
        "reason": {"type": "string"}
      }
    }
  }
}

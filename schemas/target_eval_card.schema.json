{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/evisi/target-eval-card-v0.5.schema.json",
  "title": "EviSI-Eval v0.5 Target Evaluation Card",
  "type": "object",
  "required": ["sample_id", "system_name", "si_translation", "eval_units", "target_anchors", "target_events", "target_relations", "fluency_issues", "fluency_assessment", "si_expression_issues", "si_expression_assessment", "metadata"],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "system_name": {"type": "string", "minLength": 1},
    "si_translation": {"type": "string", "minLength": 1},
    "eval_units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/eval_unit"}},
    "target_anchors": {"type": "array", "items": {"$ref": "#/$defs/target_anchor"}},
    "target_events": {"type": "array", "items": {"$ref": "#/$defs/target_event"}},
    "target_relations": {"type": "array", "items": {"$ref": "#/$defs/target_relation"}},
    "fluency_issues": {"type": "array", "items": {"$ref": "#/$defs/issue"}},
    "fluency_assessment": {"type": "string", "minLength": 1},
    "si_expression_issues": {"type": "array", "items": {"$ref": "#/$defs/issue"}},
    "si_expression_assessment": {"type": "string", "minLength": 1},
    "metadata": {"type": "object", "required": ["protocol_version", "system_name_visible_to_agents", "reference_translation_used", "validation"]}
  },
  "$defs": {
    "eval_unit": {
      "type": "object", "required": ["eval_unit_id", "source_unit_ids", "target_unit", "alignment_status", "reason"],
      "properties": {
        "eval_unit_id": {"type": "string", "pattern": "^E[1-9][0-9]*$"},
        "source_unit_ids": {"type": "array", "items": {"type": "string"}},
        "target_unit": {"type": "string"},
        "alignment_status": {"enum": ["aligned", "source_omitted", "target_addition", "uncertain"]},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "target_anchor": {"type": "object", "required": ["eval_unit_id", "target_anchor_id", "anchor_type", "anchor_text", "normalized_meaning", "evidence_span"]},
    "target_event": {"type": "object", "required": ["eval_unit_id", "target_event_id", "event_type", "event_text", "canonical_meaning", "evidence_span"]},
    "target_relation": {"type": "object", "required": ["target_relation_id", "relation_type", "relation_basis", "relation_cue", "confidence", "eval_unit_ids", "relation_text", "relation_meaning", "evidence_spans", "related_target_event_ids"], "properties": {"relation_basis": {"enum": ["explicit_cue", "strong_semantic_entailment"]}, "relation_cue": {"type": "string"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}}},
    "issue": {
      "type": "object", "required": ["issue_id", "issue_type", "target_span", "severity", "reason"],
      "properties": {"severity": {"enum": ["minor", "moderate", "major", "critical"]}}
    }
  }
}

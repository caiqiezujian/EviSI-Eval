{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/evisi/target-semantic-card-v0.5.schema.json",
  "title": "EviSI-Eval Target Semantic Card",
  "type": "object",
  "required": [
    "sample_id", "system_name", "si_translation", "source_card_hash", "eval_units",
    "target_anchors", "target_events", "target_relations", "metadata"
  ],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "system_name": {"type": "string", "minLength": 1},
    "si_translation": {"type": "string", "minLength": 1},
    "source_card_hash": {"type": "string", "minLength": 1},
    "eval_units": {"type": "array", "minItems": 1},
    "target_anchors": {"type": "array", "items": {"$ref": "#/$defs/anchor"}},
    "target_events": {"type": "array", "items": {"$ref": "#/$defs/event"}},
    "target_relations": {"type": "array", "items": {"$ref": "#/$defs/relation"}},
    "metadata": {"type": "object"}
  },
  "$defs": {
    "anchor": {
      "type": "object",
      "required": ["eval_unit_id", "target_anchor_id", "anchor_type", "anchor_text", "normalized_meaning", "evidence_span"]
    },
    "event": {
      "type": "object",
      "required": ["eval_unit_id", "target_event_id", "event_type", "event_text", "canonical_meaning", "evidence_span"]
    },
    "relation": {
      "type": "object",
      "required": [
        "target_relation_id", "relation_type", "relation_basis", "relation_cue", "confidence",
        "eval_unit_ids", "relation_text", "relation_meaning", "evidence_spans",
        "related_target_event_ids"
      ],
      "properties": {
        "relation_basis": {"enum": ["explicit_cue", "strong_semantic_entailment"]},
        "relation_cue": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
